{
  "name": "@hypedoc/cli",
  "version": "1.0.0",
  "description": "CLI for Hype Doc — log and track your wins from the terminal",
  "type": "module",
  "bin": {
    "hype": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/ test/ scripts/",
    "fmt": "oxfmt --write src/ test/",
    "fmt:check": "oxfmt --check src/ test/",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "hypedoc",
    "wins",
    "achievements",
    "cli",
    "hype"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist"
  ],
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "rolldown": "1.0.0-rc.9",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
